<!DOCTYPE html>
<html lang="<%= locale %>" dir="<%= dir %>">
<head><%- include('../partials/head') %></head>
<body class="<%= bodyClass %>">
<%- include('../partials/header') %>

<%
  var inWish = (typeof wishlistIds !== 'undefined') && wishlistIds.indexOf(product.id) !== -1;
  var waMsg = "Hi LamsaDZ! 👋 I'd like to order: " + name + " (" + helpers.formatDA(product.price) + "). SKU: " + product.sku;
  var waHref = "https://wa.me/" + settings.whatsapp_number + "?text=" + encodeURIComponent(waMsg);
%>

<main class="product-page">
  <div class="wrap">
    <nav class="breadcrumb">
      <a href="/">Home</a> / <a href="/shop">Shop</a>
      <% if (product.category_slug) { %> / <a href="/shop?category=<%= product.category_slug %>"><%= product.category_slug.replace(/-/g,' ') %></a><% } %>
      / <span><%= name %></span>
    </nav>

    <div class="product-detail">
      <!-- Gallery -->
      <div class="pd-gallery">
        <div class="pd-main">
          <% if (product.tag) { %><span class="tag tag-<%= product.tag.toLowerCase() %>"><%= product.tag %></span><% } %>
          <% if (product.discount_pct > 0) { %><span class="tag tag-discount">-<%= product.discount_pct %>%</span><% } %>
          <% if (images.length) { %>
            <img id="pdMainImg" src="<%= images[0].url %>" alt="<%= name %>" width="500" height="500" />
          <% } else { %>
            <div class="product-icon-fallback" style="aspect-ratio:1/1"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" width="100" height="100"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M3 16l5-5 4 4 3-3 6 6"/></svg></div>
          <% } %>
        </div>
        <% if (images.length > 1) { %>
          <div class="pd-thumbs">
            <% images.forEach(function(im, i){ %>
              <button class="pd-thumb <%= i===0?'active':'' %>" data-src="<%= im.url %>"><img src="<%= im.url %>" alt="" /></button>
            <% }); %>
          </div>
        <% } %>
      </div>

      <!-- Info -->
      <div class="pd-info">
        <h1><%= name %></h1>
        <div class="pd-meta">
          <span class="pd-sku">SKU: <%= product.sku %></span>
          <% if (reviewStats.count) { %>
            <span class="pd-rating"><span class="stars"><% for(var s=0;s<Math.round(reviewStats.avg);s++){ %>★<% } %></span> <%= reviewStats.avg %> (<%= reviewStats.count %>)</span>
          <% } %>
        </div>

        <div class="pd-price">
          <span class="price"><%= helpers.formatDA(product.price) %></span>
          <% if (product.old_price && product.old_price > product.price) { %>
            <span class="old"><%= helpers.formatDA(product.old_price) %></span>
            <span class="save-badge"><%= t('save_label') %> <%= helpers.formatDA(product.old_price - product.price) %></span>
          <% } %>
        </div>

        <div class="pd-stock">
          <% if (!product.in_stock) { %><span class="stock-pill stock-out"><%= t('out_of_stock') %></span>
          <% } else if (product.low_stock) { %><span class="stock-pill stock-low"><%= t('low_stock') %> (<%= product.stock %>)</span>
          <% } else { %><span class="stock-pill stock-in"><%= t('in_stock') %></span><% } %>
        </div>

        <p class="pd-desc"><%= desc %></p>

        <div class="pd-actions">
          <a class="btn btn-wa btn-lg wa-track" data-wa-key="order" data-product-id="<%= product.id %>" href="<%= waHref %>" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.8 4.9-1.3A10 10 0 1 0 12 2z"/></svg>
            <%= t('order_btn') %>
          </a>
          <button class="btn btn-ghost-gold wish-btn-lg <%= inWish?'active':'' %>" data-wish="<%= product.id %>" type="button">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="<%= inWish?'currentColor':'none' %>" stroke="currentColor" stroke-width="2"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1.1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"/></svg>
            <%= t('add_wishlist') %>
          </button>
          <button class="btn btn-ghost" data-compare="<%= product.id %>" type="button"><%= t('add_compare') %></button>
        </div>

        <!-- Trust mini-badges -->
        <ul class="pd-trust">
          <li>🛡️ <%= t('badge_warranty') %></li>
          <li>🚚 <%= t('badge_delivery') %></li>
          <li>💵 <%= t('badge_cod') %></li>
          <li>✅ <%= t('badge_original') %></li>
        </ul>
      </div>
    </div>

    <!-- Reviews -->
    <section class="pd-reviews">
      <h2><%= t('testimonials_title') %></h2>
      <div class="reviews-list">
        <% if (!reviews.length) { %><p class="muted">No reviews yet. Be the first!</p><% } %>
        <% reviews.forEach(function(r){ %>
          <div class="review">
            <div class="stars"><% for(var s=0;s<r.rating;s++){ %>★<% } %></div>
            <p><%= r.body %></p>
            <span class="review-author">— <%= r.author_name %></span>
          </div>
        <% }); %>
      </div>

      <form class="review-form" id="reviewForm">
        <h3>Write a review</h3>
        <input type="hidden" name="product_id" value="<%= product.id %>" />
        <input type="text" name="author_name" placeholder="Your name" required />
        <select name="rating" required>
          <option value="5">★★★★★ (5)</option>
          <option value="4">★★★★ (4)</option>
          <option value="3">★★★ (3)</option>
          <option value="2">★★ (2)</option>
          <option value="1">★ (1)</option>
        </select>
        <textarea name="body" rows="3" placeholder="Share your experience" required></textarea>
        <input type="text" name="website" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
        <button type="submit" class="btn btn-gold">Submit review</button>
        <p class="form-msg" id="reviewMsg" aria-live="polite"></p>
      </form>
    </section>

    <!-- Related -->
    <% if (related.length) { %>
    <section class="pd-related">
      <div class="sec-head" style="text-align:start"><div class="gold-line-left"></div><h2><%= t('related_title') %></h2></div>
      <div class="product-grid">
        <% related.forEach(function(rp){ %><%- include('../partials/product-card', { product: rp, wishlistIds: wishlistIds }) %><% }); %>
      </div>
    </section>
    <% } %>
  </div>
</main>

<%- include('../partials/footer') %>
<%- include('../partials/wa-float') %>
<%- include('../partials/scripts') %>

<!-- Product structured data -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": <%- JSON.stringify(name) %>,
  "description": <%- JSON.stringify(desc) %>,
  "sku": "<%= product.sku %>",
  <% if (images.length) { %>"image": "<%= config.siteUrl %><%= images[0].url %>",<% } %>
  "offers": {
    "@type": "Offer",
    "priceCurrency": "DZD",
    "price": "<%= product.price %>",
    "availability": "<%= product.in_stock ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock' %>",
    "url": "<%= config.siteUrl %>/product/<%= product.slug %>"
  }
  <% if (reviewStats.count) { %>,
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "<%= reviewStats.avg %>", "reviewCount": "<%= reviewStats.count %>" }
  <% } %>
}
</script>

<script>
// thumbnail switcher
document.querySelectorAll('.pd-thumb').forEach(function(b){
  b.addEventListener('click', function(){
    var main = document.getElementById('pdMainImg');
    if (main) main.src = b.getAttribute('data-src');
    document.querySelectorAll('.pd-thumb').forEach(function(x){x.classList.remove('active');});
    b.classList.add('active');
  });
});
</script>
</body>
</html>
