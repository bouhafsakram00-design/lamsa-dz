<!DOCTYPE html>
<html lang="<%= typeof locale !== 'undefined' ? locale : 'en' %>" dir="<%= typeof dir !== 'undefined' ? dir : 'ltr' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= code %> — LamsaDZ</title>
  <link rel="icon" type="image/jpeg" href="/img/favicon.jpg" />
  <link rel="stylesheet" href="/css/theme.css" />
  <link rel="stylesheet" href="/css/app.css" />
</head>
<body>
  <main class="error-page">
    <div>
      <h1><%= code %></h1>
      <p><%= message %></p>
      <a href="/" class="btn btn-gold">← Back to home</a>
    </div>
  </main>
</body>
</html>
