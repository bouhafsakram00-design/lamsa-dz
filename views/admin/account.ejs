<%- include('./_layout-open') %>
  <div class="admin-head"><div><h1>My Account</h1><p class="sub">Change your admin password</p></div></div>

  <% if (success) { %><div class="alert alert-success">✅ Your password was changed successfully.</div><% } %>
  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

  <form method="post" action="/admin/account/password">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="panel" style="max-width:520px">
      <div class="panel-head"><h2>🔐 Change password</h2></div>
      <div class="panel-body">
        <div class="form-row">
          <label>Current password</label>
          <input type="password" name="current_password" required autocomplete="current-password" placeholder="Enter your current password">
        </div>
        <div class="form-row" style="margin-top:14px">
          <label>New password</label>
          <input type="password" name="new_password" required minlength="8" autocomplete="new-password" placeholder="At least 8 characters">
        </div>
        <div class="form-row" style="margin-top:14px">
          <label>Confirm new password</label>
          <input type="password" name="confirm_password" required minlength="8" autocomplete="new-password" placeholder="Type the new password again">
        </div>
        <div class="form-actions">
          <button class="btn btn-primary">Update password</button>
        </div>
        <p class="muted" style="margin-top:14px;font-size:13px">
          💡 Tip: use a strong password with letters, numbers and a symbol.
          On the free hosting tier, this change lasts until the next restart —
          for a permanent change also update <code>ADMIN_PASSWORD</code> in Render.
        </p>
      </div>
    </div>
  </form>
<%- include('./_layout-close') %>
