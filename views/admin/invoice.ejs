<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><title>Invoice <%= order.reference %></title>
<style>
  *{box-sizing:border-box;margin:0;padding:0;font-family:'Segoe UI',Arial,sans-serif}
  body{padding:40px;color:#0A0F1A;font-size:14px}
  .inv-head{display:flex;justify-content:space-between;border-bottom:3px solid #0F4C81;padding-bottom:20px;margin-bottom:24px}
  .inv-head h1{font-size:26px;color:#0F4C81}
  .inv-meta{text-align:right;color:#555;font-size:13px}
  .parties{display:flex;justify-content:space-between;margin-bottom:24px;gap:20px}
  .parties h3{font-size:12px;text-transform:uppercase;color:#888;letter-spacing:1px;margin-bottom:6px}
  table{width:100%;border-collapse:collapse;margin-bottom:20px}
  th,td{padding:11px;text-align:left;border-bottom:1px solid #e8ecf1}
  th{background:#f4f7fb;font-size:12px;text-transform:uppercase;color:#555}
  .tot{margin-left:auto;width:280px}
  .tot div{display:flex;justify-content:space-between;padding:7px 0}
  .tot .grand{border-top:2px solid #0F4C81;font-size:18px;font-weight:800;color:#0F4C81;margin-top:6px;padding-top:12px}
  .foot{margin-top:40px;text-align:center;color:#888;font-size:12px;border-top:1px solid #e8ecf1;padding-top:16px}
  @media print{.noprint{display:none}}
  .noprint{margin-bottom:20px}
  .btn{background:#0F4C81;color:#fff;border:0;padding:10px 18px;border-radius:8px;cursor:pointer;font-size:14px}
</style>
</head>
<body>
  <div class="noprint"><button class="btn" onclick="window.print()">🖨️ Print / Save PDF</button></div>
  <div class="inv-head">
    <div><h1><%= settings.store_name %></h1><div style="color:#555;font-size:13px"><%= settings.store_address %><br><%= settings.store_phone %></div></div>
    <div class="inv-meta"><strong style="font-size:18px">INVOICE</strong><br><%= order.reference %><br><%= order.created_at.slice(0,10) %><br>Status: <b><%= order.status %></b></div>
  </div>
  <div class="parties">
    <div><h3>Billed to</h3><strong><%= order.customer_name || '—' %></strong><br><%= order.customer_phone || '' %><br><%= order.email || '' %><br><%= order.wilaya || '' %> <%= order.address || '' %></div>
  </div>
  <table>
    <thead><tr><th>Item</th><th>Unit price</th><th>Qty</th><th style="text-align:right">Amount</th></tr></thead>
    <tbody>
      <% order.items.forEach(function(it){ %>
        <tr><td><%= it.name %></td><td><%= helpers.formatDA(it.unit_price) %></td><td><%= it.qty %></td><td style="text-align:right"><%= helpers.formatDA(it.unit_price*it.qty) %></td></tr>
      <% }); %>
    </tbody>
  </table>
  <div class="tot">
    <div><span>Subtotal</span><span><%= helpers.formatDA(order.subtotal) %></span></div>
    <% if (order.discount) { %><div><span>Discount</span><span>−<%= helpers.formatDA(order.discount) %></span></div><% } %>
    <div><span>Shipping</span><span><%= order.shipping ? helpers.formatDA(order.shipping) : 'Free' %></span></div>
    <div class="grand"><span>Total</span><span><%= helpers.formatDA(order.total) %></span></div>
  </div>
  <div class="foot">Thank you for shopping with <%= settings.store_name %> · <%= settings.store_phone %></div>
</body>
</html>
