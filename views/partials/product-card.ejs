<%
  // expects: product (decorated), and optionally wishlistIds array
  var name = field(product, 'name');
  var inWish = (typeof wishlistIds !== 'undefined') && wishlistIds.indexOf(product.id) !== -1;
  var waMsg = "Hi LamsaDZ! 👋 I'd like to order: " + name + " (" + helpers.formatDA(product.price) + ").";
  var waHref = "https://wa.me/" + settings.whatsapp_number + "?text=" + encodeURIComponent(waMsg);
%>
<article class="product-card reveal" data-product-id="<%= product.id %>" data-name="<%= name %>">
  <a class="product-media" href="/product/<%= product.slug %>">
    <% if (product.tag) { %><span class="tag tag-<%= product.tag.toLowerCase() %>"><%= product.tag %></span><% } %>
    <% if (product.discount_pct > 0) { %><span class="tag tag-discount">-<%= product.discount_pct %>%</span><% } %>
    <% if (product.image) { %>
      <img src="<%= product.image %>" alt="<%= name %>" loading="lazy" decoding="async" width="300" height="300" />
    <% } else { %>
      <div class="product-icon-fallback">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M3 16l5-5 4 4 3-3 6 6"/><circle cx="8.5" cy="8.5" r="1.5"/></svg>
      </div>
    <% } %>

    <button class="wish-btn <%= inWish ? 'active' : '' %>" data-wish="<%= product.id %>" aria-label="<%= t('add_wishlist') %>" type="button">
      <svg viewBox="0 0 24 24" fill="<%= inWish ? 'currentColor' : 'none' %>" stroke="currentColor" stroke-width="2"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1.1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"/></svg>
    </button>
  </a>

  <div class="product-body">
    <a href="/product/<%= product.slug %>" class="product-name"><%= name %></a>
    <p class="product-desc"><%= helpers.truncate(field(product, 'desc'), 70) %></p>

    <div class="stock-row">
      <% if (!product.in_stock) { %>
        <span class="stock-pill stock-out"><%= t('out_of_stock') %></span>
      <% } else if (product.low_stock) { %>
        <span class="stock-pill stock-low"><%= t('low_stock') %></span>
      <% } else { %>
        <span class="stock-pill stock-in"><%= t('in_stock') %></span>
      <% } %>
    </div>

    <div class="price-row">
      <div>
        <span class="price"><%= helpers.formatDA(product.price) %></span>
        <% if (product.old_price && product.old_price > product.price) { %>
          <span class="old"><%= helpers.formatDA(product.old_price) %></span>
        <% } %>
      </div>
    </div>

    <a class="btn btn-wa btn-block wa-track" data-wa-key="order" data-product-id="<%= product.id %>"
       href="<%= waHref %>" target="_blank" rel="noopener"
       <%= product.in_stock ? '' : 'aria-disabled="true"' %>>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.8 4.9-1.3A10 10 0 1 0 12 2z"/></svg>
      <%= t('order_btn') %>
    </a>
  </div>
</article>
