# ============================================================
#  LamsaDZ — Environment Configuration
#  Copy this file to ".env" and fill in real values.
#  NEVER commit your real .env to source control.
# ============================================================

# --- Server ---
NODE_ENV=development
PORT=3000
# Public base URL (used for canonical links, sitemap, og tags)
SITE_URL=http://localhost:3000

# --- Database ---
# driver: "sqlite" (default, zero-config) or "postgres"
DB_DRIVER=sqlite
# For sqlite: path to file
SQLITE_PATH=./db/lamsadz.sqlite
# For postgres (only used when DB_DRIVER=postgres)
DATABASE_URL=postgres://user:password@localhost:5432/lamsadz

# --- Sessions / Security ---
# Generate strong random strings: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string
# Set to "true" only when served over HTTPS in production
SECURE_COOKIES=false

# --- Default admin (created on first seed) ---
ADMIN_EMAIL=admin@lamsadz.dz
ADMIN_PASSWORD=ChangeMe!2026
ADMIN_NAME=Akram

# --- Store / Business settings (overridable in admin UI) ---
WHATSAPP_NUMBER=213796472662
STORE_NAME=LamsaDZ
STORE_ADDRESS=Hai 119 Logements, Tissemsilt, Algeria
STORE_EMAIL=contact@lamsadz.dz
STORE_PHONE=+213 796 472 662

# --- Analytics ---
# Optional: Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX). Leave blank to disable.
GA_MEASUREMENT_ID=

# --- Uploads ---
# Optional: store uploads on a persistent disk (e.g. Render: /var/data/uploads)
# UPLOADS_DIR=
MAX_UPLOAD_MB=5
