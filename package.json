    "seed": "node scripts/seed.js",
    "setup": "node scripts/migrate.js && node scripts/seed.js",
    "test": "node --test tests/"
  },
  "keywords": [
    "ecommerce",
    "algeria",
    "electronics",
    "whatsapp",
    "express"
