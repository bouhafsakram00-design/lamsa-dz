{
  "name": "lamsadz",
  "version": "1.0.0",
  "description": "LamsaDZ — Production-ready electronics & tech e-commerce store for Algeria (Node.js + Express + SQLite/Postgres).",
  "main": "src/server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
